# === Postgres (consumed by the `db` service) ===
POSTGRES_DB=quizanchos
POSTGRES_USER=quizanchos
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# === App's connection string (Host=db resolves on the compose network) ===
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=quizanchos;Username=quizanchos;Password=CHANGE_ME_strong_password_here;

# === Auth ===
Auth__Cookie__TokenValidityInMinutes=10080
Auth__Google__ClientId=
Auth__Google__ClientSecret=

# === Owner seed account (created on first startup) ===
Owner__Email=
Owner__Password=

# === Cloudinary (avatar uploads) ===
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=

# === Email (Mailgun) ===
EmailConfirmation__ShouldUse=1
EmailConfirmation__MailGun__FromEmail=
EmailConfirmation__MailGun__FromName=
EmailConfirmation__MailGun__Domain=
EmailConfirmation__MailGun__ApiKey=

# === Payments (Binance) ===
BinanceApi__ApiKey=
BinanceApi__ApiSecret=
BinanceApi__UsdtAddressBep20=
BinanceApi__UsdtAddressTrc20=

# === Cloudflare Tunnel ===
CF_TUNNEL_TOKEN=
