@using Quizanchos.Common.Enums
@using Quizanchos.Common.Quiz.Enums
@{
    ViewData["Title"] = "Quiz Multiplayer — Lobby";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="/minigames/quiz-multiplayer/css/quiz-multiplayer-lobby.css">
</head>
<body>
<main class="lobby-container">

    <!-- ?? Create Room Panel ??????????????????????????????????????? -->
    <section class="panel create-panel">
        <h1>Quiz Multiplayer</h1>
        <p class="subtitle">Create a new room or join an existing one</p>

        <form id="createRoomForm" class="create-form">
            <div class="form-row">
                <div class="form-group">
                    <label for="categorySelect">Category</label>
                    <select id="categorySelect" class="form-control">
                        <option value="">Loading…</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="teamCount">Teams</label>
                    <select id="teamCount" class="form-control">
                        <option value="2" selected>2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="playersPerTeam">Players / team</label>
                    <select id="playersPerTeam" class="form-control">
                        <option value="1">1</option>
                        <option value="2" selected>2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="totalCards">Cards</label>
                    <select id="totalCards" class="form-control">
                        @foreach (var v in Enum.GetValues(typeof(CardCountEnum)))
                        {
                            <option value="@((int)v)">@v</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="secondsPerCard">Seconds / card</label>
                    <select id="secondsPerCard" class="form-control">
                        @foreach (var v in Enum.GetValues(typeof(SecondsPerCardEnum)))
                        {
                            <option value="@((int)v)">@v</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="optionCount">Options</label>
                    <select id="optionCount" class="form-control">
                        @foreach (var v in Enum.GetValues(typeof(OptionCountEnum)))
                        {
                            <option value="@((int)v)">@v</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="gameLevel">Level</label>
                    <select id="gameLevel" class="form-control">
                        @foreach (var level in Enum.GetValues(typeof(GameLevel)))
                        {
                            <option value="@((int)level)">@level</option>
                        }
                    </select>
                </div>
            </div>

            <button type="submit" class="btn-create">Create Room</button>
        </form>
    </section>

    <!-- ?? Available Rooms List ????????????????????????????????????? -->
    <section class="panel rooms-panel">
        <div class="rooms-header">
            <h2>Available Rooms</h2>
            <button id="refreshBtn" class="btn-refresh" title="Refresh">?</button>
        </div>

        <div id="roomsList" class="rooms-list">
            <p class="empty-msg">Loading rooms…</p>
        </div>
    </section>

    <!-- ?? Room Detail / Waiting Area (hidden until joined) ???????? -->
    <section class="panel room-detail-panel" id="roomDetail" style="display:none;">
        <h2 id="roomTitle">Room</h2>
        <p id="roomStatus" class="room-status"></p>

        <div id="teamsGrid" class="teams-grid"></div>

        <div class="room-actions">
            <button id="leaveRoomBtn" class="btn-leave">Leave Room</button>
        </div>
    </section>

</main>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
    window.minigameConfig = {
        minigameTypeId: @ViewBag.MinigameTypeId,
        gameUrlTemplate: '@ViewBag.GameUrlTemplate',
        lobbyUrl: '@ViewBag.LobbyUrl'
    };
</script>
<script src="/minigames/quiz-multiplayer/js/quiz-multiplayer-lobby.js" asp-append-version="true"></script>
</body>
</html>
