@{
    ViewData["Title"] = "Quiz Multiplayer";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="/minigames/quiz-multiplayer/css/quiz-multiplayer.css">
</head>
<body>
<div class="qm-container" data-game-id="@ViewBag.GameId" id="qm-container" style="display:none;">
    <div class="qm-header" id="qm-header">
        <h1 id="qm-question">Loading...</h1>
        <div class="question-info">
            <span id="question-number">Question <span data-current>1</span> of <span data-total>10</span></span>
        </div>
    </div>

    <!-- Team scoreboard -->
    <div class="qm-scoreboard" id="qm-scoreboard">
        <!-- Populated dynamically -->
    </div>

    <!-- Waiting indicator -->
    <div class="qm-waiting" id="qm-waiting" style="display:none;">
        <p>Waiting for other players... <span id="qm-answered-count">0</span>/<span id="qm-total-players">0</span></p>
    </div>

    <div class="timeline-container" id="timeline-container">
        <div class="timeline" id="timeline"></div>
    </div>

    <div class="quiz-options" id="qm-options">
        <!-- Options will be loaded dynamically -->
    </div>
</div>

<div id="loading-container" style="display: flex; justify-content: center; align-items: center; height: 100vh;">
    <div id="loader"></div>
</div>

<div id="errorModal" class="modal" style="display: none;">
    <div class="modal-content">
        <span class="close-btn" id="closeModal">&times;</span>
        <h2 id="modalHeader">Error</h2>
        <p id="modalErrorText"></p>
        <div id="modalButtons" class="modal-buttons">
            <button id="returnToMenu">Return to Menu</button>
        </div>
    </div>
</div>

<div id="roundResultModal" class="modal" style="display: none;">
    <div class="modal-content">
        <h2>Round Results</h2>
        <div id="roundResultBody"></div>
    </div>
</div>

<div id="finalStatsModal" class="modal" style="display: none;">
    <div class="modal-content">
        <h2 id="finalTitle">Game Over!</h2>
        <div id="finalScoreboard"></div>
        <p id="winnerText"></p>
        <button id="goToResults">Return to Main Menu</button>
    </div>
</div>

<div id="preloader">
    <div id="loader"></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
    window.minigameConfig = {
        minigameTypeId: @ViewBag.MinigameTypeId,
        gameUrlTemplate: '@ViewBag.GameUrlTemplate',
        lobbyUrl: '@ViewBag.LobbyUrl'
    };
</script>
<script src="/js/game-client.js" asp-append-version="true"></script>
<script src="/minigames/quiz-multiplayer/js/quiz-multiplayer-client.js" asp-append-version="true"></script>
<script src="/minigames/quiz-multiplayer/js/quiz-multiplayer-game.js" asp-append-version="true"></script>
</body>
</html>
