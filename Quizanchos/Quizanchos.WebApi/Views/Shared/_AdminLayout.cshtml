@using Quizanchos.WebApi.Constants
@{
    var requestPath = Context.Request.Path.Value ?? "";
    bool IsActive(string path)
    {
        if (path == "/Admin")
            return string.Equals(requestPath, "/Admin", StringComparison.OrdinalIgnoreCase) ||
                   string.Equals(requestPath, "/Admin/", StringComparison.OrdinalIgnoreCase);
        return requestPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#7c3aed">
    <title>@ViewData["Title"] · Quizanchos Admin</title>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true">
    <link rel="stylesheet" href="/css/admin.css" asp-append-version="true">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<a class="skip-link" href="#admin-main">Skip to main content</a>

<header class="navbar" role="banner">
    <div class="container">
        <a href="/Admin" class="logo" aria-label="Quizanchos admin home">
            Quizanchos
            <span class="admin-pill" aria-hidden="true">Admin</span>
        </a>

        <button class="burger-menu"
                aria-label="Toggle navigation"
                aria-controls="admin-nav"
                aria-expanded="false">
            <span></span><span></span><span></span>
        </button>

        @if (User.IsInRole(AppRole.Owner) || User.IsInRole(AppRole.Admin))
        {
            <nav class="nav-list" id="admin-nav" aria-label="Admin">
                <ul>
                    <li><a href="/Admin" class="@(IsActive("/Admin") && requestPath.TrimEnd('/').EndsWith("/Admin") ? "active" : "")">Dashboard</a></li>
                    <li><a href="/Admin/Statistics" class="@(IsActive("/Admin/Statistics") ? "active" : "")">Statistics</a></li>
                    <li><a href="/Admin/Users" class="@(IsActive("/Admin/Users") ? "active" : "")">Users</a></li>
                    <li><a href="/Admin/CreateQuiz" class="@(IsActive("/Admin/CreateQuiz") ? "active" : "")">Create Quiz</a></li>
                    <li><a href="/Admin/TopUp" class="@(IsActive("/Admin/TopUp") ? "active" : "")">Top-Ups</a></li>
                    <li><a href="/Admin/Settings" class="@(IsActive("/Admin/Settings") ? "active" : "")">Settings</a></li>
                    <li><a href="/Admin/Logs" class="@(IsActive("/Admin/Logs") ? "active" : "")">Logs</a></li>
                </ul>
            </nav>

            <div class="auth-buttons">
                <a href="/" class="btn btn-secondary" title="Switch to user view">User view</a>
                <form method="post" action="/Account/Logout" class="logout-form">
                    <button type="submit" class="btn-logout">Logout</button>
                </form>
            </div>
        }
    </div>
</header>

<main id="admin-main" class="container app-shell" role="main">
    @RenderBody()
</main>

<footer class="quiz-footer" role="contentinfo">
    <div class="container">
        <span>&copy; @DateTime.Now.Year Quizanchos Admin</span>
        <span class="footer-separator" aria-hidden="true">•</span>
        <span>Course work by Danchos &amp; Vanchos</span>
        <span class="footer-separator" aria-hidden="true">•</span>
        <a href="https://github.com/navarti/Quizanchos" class="footer-link" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
</footer>

<script src="/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
