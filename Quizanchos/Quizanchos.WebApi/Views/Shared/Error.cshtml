@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="auth-page" aria-labelledby="error-title">
    <article class="surface-card" style="max-width: 640px; width: 100%;">
        <h1 id="error-title" class="text-danger" style="margin-bottom: var(--space-3);">Something went wrong</h1>
        <p class="text-muted" style="margin-bottom: var(--space-4);">An error occurred while processing your request.</p>

        @if (Model.ShowRequestId)
        {
            <p style="margin-bottom: var(--space-4);">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <h2 style="font-size: var(--font-size-lg); margin-bottom: var(--space-2);">Development Mode</h2>
        <p style="margin-bottom: var(--space-3);">
            Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
        </p>
        <p>
            <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
            For local debugging, set <strong>ASPNETCORE_ENVIRONMENT</strong> to <strong>Development</strong> and restart the app.
        </p>

        <p style="margin-top: var(--space-5);">
            <a href="/" class="btn btn-primary">Back to Home</a>
        </p>
    </article>
</section>
