<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Quizzes</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/site.css">
    <link rel="stylesheet" href="/css/multiplayer-game-chat.css" asp-append-version="true">
</head>
<body data-user-id="@(User.Identity?.IsAuthenticated == true ? User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier) : "")">

<header class="navbar">
    <div class="container">
        <a href="/" class="logo">Quizanchos</a>
        <button class="burger-menu" aria-label="Toggle navigation">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <nav class="nav-list">
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/Minigames">Minigames</a></li>
                <li><a href="/LeaderBoard">LeaderBoard</a></li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li><a href="/Market">Market</a></li>
                }
                <li><a href="/FAQ">FAQ</a></li>
                <li><a href="/Contact">Contact</a></li>
            </ul>
        </nav>
            <div class="auth-buttons">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Account/Balance" class="user-balance" id="user-balance">
                        <span class="balance-label">Balance:</span>
                        <span class="balance-value" id="user-balance-value">0</span>
                        <span class="balance-currency">coins</span>
                    </a>
                    <a href="/Account/Profile" class="btn-profile">
                        <img src="https://cdn-icons-png.flaticon.com/512/7153/7153150.png" alt="Profile Icon" class="profile-icon">
                        <span>Profile</span>
                    </a>
                <a href="javascript:void(0);" class="btn-logout" onclick="logout()">Logout</a>
                }
                else
                {
                    <a href="/Signup" class="btn btn-secondary">Sign up</a>
                    <a href="/Signin" class="btn btn-primary">Sign in</a>
                }
            </div>
    </div>
</header>


<main class="container">
    @RenderBody()
    <div id="errorModal" class="modal" style="display: none;">
        <div class="modal-content">
            <span class="close-btn" id="closeModal">&times;</span>
            <h2 id="modalHeader">Notification</h2>
            <p id="modalErrorText"></p>
            <div id="modalButtons" class="modal-buttons"></div>
        </div>
    </div>
</main>

<footer class="border-top footer text-muted fixed-bottom">
    <div class="container">
        &copy; 2024 - Course work by: Danchos & Vanchos - <a href="https://github.com/navarti/Quizanchos">Github</a>
    </div>
</footer>

<script src="/js/common.js" asp-append-version="true"></script>
<script src="/js/site.js" asp-append-version="true"></script>
<script src="/js/profile.js" asp-append-version="true"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script src="/js/multiplayer-game-chat.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
