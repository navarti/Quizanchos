@model Quizanchos.WebApi.Dto.FullApplicationUserDto
@{
    ViewData["Title"] = "Market";
}

@section Styles {
    <link rel="stylesheet" href="/css/profile.css" asp-append-version="true">
    <link rel="stylesheet" href="/css/balance.css" asp-append-version="true">
    <link rel="stylesheet" href="/css/market.css" asp-append-version="true">
}

<section class="profile-container">
    <header class="balance-hero" style="margin-bottom: var(--space-6);">
        <span class="eyebrow">Spend your coins</span>
        <h1>Market</h1>
        <p class="balance-subtitle">Unlock premium minigames and chat emojis.</p>
    </header>

    <div class="profile-card market-card">
        <div class="market-balance-row">
            <div>
                <p class="market-balance-caption">Available balance</p>
                <p class="market-balance-value"><span id="market-balance">@Model.Coins</span> coins</p>
            </div>
            <a href="/Account/Balance" class="btn btn-primary market-balance-link">Top up</a>
        </div>

        <div id="market-status" hidden></div>

        <h2 class="market-section-title">Premium Subscriptions</h2>
        <div id="market-grid-premium" class="market-grid"></div>

        <h2 class="market-section-title">Emoji Catalog</h2>
        <div id="market-grid-emoji" class="market-grid"></div>
    </div>
</section>

@section Scripts {
    <script src="/js/market.js" asp-append-version="true"></script>
}
