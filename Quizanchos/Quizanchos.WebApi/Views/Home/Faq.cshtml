@{
    ViewData["Title"] = "FAQ";
}

<main class="about-container">
    <h1 class="page-title">FAQ</h1>
    <p class="welcome-text">Answers about core Quizanchos functionality.</p>

    <section class="about-section">
        <h2>How do I start playing?</h2>
        <p>Open the <a href="/Minigames" class="contact-link">Minigames</a> page, choose a minigame, and join its lobby. Some minigames can be played solo, while others are multiplayer.</p>
    </section>

    <section class="about-section">
        <h2>How does my active session work?</h2>
        <p>If you leave a running game, the Home page shows <strong>Your Active Session</strong>. Use <strong>Continue</strong> to return to the same minigame and game room.</p>
    </section>

    <section class="about-section">
        <h2>How are leaderboard scores calculated?</h2>
        <p>Your position on <a href="/LeaderBoard" class="contact-link">LeaderBoard</a> is based on your points earned in minigames. Higher total score means a higher position.</p>
    </section>

    <section class="about-section">
        <h2>What are coins used for?</h2>
        <p>Coins are shown in the top navigation after login. You can spend them in the <a href="/Market" class="contact-link">Market</a> on available profile items.</p>
    </section>

    <section class="about-section">
        <h2>How can I update my profile?</h2>
        <p>Go to <a href="/Account/Profile" class="contact-link">Profile</a> to change your nickname or avatar.</p>
    </section>

    <section class="about-section">
        <h2>Still need help?</h2>
        <p>If your issue is not covered here, contact us via the <a href="/Contact" class="contact-link">Contact</a> page.</p>
    </section>
</main>

