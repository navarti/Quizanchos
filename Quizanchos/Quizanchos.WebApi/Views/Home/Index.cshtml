@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/home.css">
</head>
<body>
<div class="hero-waves">
    <div class="wave"></div>
    <div class="wave"></div>
    <div class="wave"></div>
</div>
<main>
        @if (User.Identity?.IsAuthenticated == true)
        {
        if (Model.ActiveSession != null)
        {
            <div class="sessions-card">
                <h2>Your Active Session</h2>
                <div class="session-item">
                    <div class="session-info">
                        <p><strong>Minigame:</strong> @(Model.ActiveSessionMinigameName ?? Model.ActiveSession.MinigameType.ToString())</p>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.ActiveSessionUrl))
                    {
                        <a href="@Model.ActiveSessionUrl" class="join-btn">Continue →</a>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="sessions-card">
                <h2>Active Sessions</h2>
                <p>No active sessions available.</p>
            </div>
        }
    }
    else
    {
        <p>Please log in to view your active sessions.</p>
    }
    <div class="stats-grid">
        <div class="stat-card">
            <h3>Total Minigames</h3>
            <p class="stat-number">@Model.Minigames.Count</p>
        </div>
        <div class="stat-card">
            <h3>Active Users</h3>
            <p class="stat-number">@Model.ActiveUsersCount</p>
        </div>
    </div>
</main>

<script src="/js/home.js" asp-append-version="true"></script>
</body>
</html>
