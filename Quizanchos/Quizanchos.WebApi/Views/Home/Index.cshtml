@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/home.css">
</head>
<body>
<div class="hero-waves">
    <div class="wave"></div>
    <div class="wave"></div>
    <div class="wave"></div>
</div>
<main>
        @if (User.Identity?.IsAuthenticated == true)
        {
        if (Model.ActiveSession != null)
        {
            <div class="sessions-card">
                <h2>Your Active Session</h2>
                <div class="session-item">
                    <div class="session-info">
                        <p><strong>Minigame:</strong> @Model.ActiveSession.MinigameType</p>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.ActiveSessionUrl))
                    {
                        <a href="@Model.ActiveSessionUrl" class="join-btn">Continue →</a>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="sessions-card">
                <h2>Active Sessions</h2>
                <p>No active sessions available.</p>
            </div>
        }
    }
    else
    {
        <p>Please log in to view your active sessions.</p>
    }
    <div class="stats-grid">
        <div class="stat-card">
            <h3>Total Quizzes</h3>
            <p class="stat-number">42</p>
        </div>
        <div class="stat-card">
            <h3>Active Users</h3>
            <p class="stat-number">1,337</p>
        </div>
        <div class="stat-card">
            <h3>Total Points</h3>
            <p class="stat-number">98,765</p>
        </div>
    </div>

    <div class="leaderboards-grid">
        <div class="leaderboard-card">
            <h3>Current Leaderboard</h3>
            <div class="leaderboard-list">
                @foreach (var user in Model.Users.Take(3).Select((user, index) => new { User = user, Rank = index + 1 }))
                {
                    <div class="leaderboard-item">
                        <span class="rank">@user.Rank</span>
                        <span class="username">@user.User.UserName</span>
                        <span class="points">@user.User.Score pts</span>
                    </div>
                }
            </div>
        </div>
        <div class="leaderboard-card">
            <h3>This month prizes</h3>
            <div class="leaderboard-list">
                <div class="leaderboard-item">
                    <span class="rank">1</span>
                    <span class="username">Amazon Gift Card</span>
                    <span class="points">$100</span>
                </div>
                <div class="leaderboard-item">
                    <span class="rank">2</span>
                    <span class="username">Amazon Gift Card</span>
                    <span class="points">$50</span>
                </div>
                <div class="leaderboard-item">
                    <span class="rank">3</span>
                    <span class="username">Amazon Gift Card</span>
                    <span class="points">$25</span>
                </div>
            </div>
        </div>
    </div>
</main>

<script src="/js/home.js" asp-append-version="true"></script>
</body>
</html>
