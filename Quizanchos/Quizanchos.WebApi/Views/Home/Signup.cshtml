@{
    ViewData["Title"] = "Sign Up";
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
}

<section class="signup-page" aria-labelledby="signup-title">
    <div class="signup-form">
        <h2 id="signup-title">Create your account</h2>
        <p>Sign up in 2 minutes and start fighting for the top spot of the month.</p>

        <div class="google-signup-container">
            <button type="button" class="google-signup-btn" onclick="window.location.href='/GoogleAuth/SignIn@(string.IsNullOrEmpty(returnUrl) ? "" : "?returnUrl=" + Uri.EscapeDataString(returnUrl))'">
                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c1/Google_%22G%22_logo.svg/768px-Google_%22G%22_logo.svg.png" alt="" aria-hidden="true">
                <span>Sign up with Google</span>
            </button>
        </div>

        <div class="separator" aria-hidden="true"><span>or</span></div>

        <form id="signupForm" novalidate data-return-url="@returnUrl">
            <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" autocomplete="email" required autofocus>
                <small class="error-message" id="emailError" role="alert"></small>
            </div>
            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <div class="password-field">
                    <input type="password" id="password" name="password" class="form-control" placeholder="At least 8 characters" autocomplete="new-password" required minlength="8">
                    <button type="button" class="password-toggle" data-toggle-target="password" aria-label="Show password" aria-pressed="false">Show</button>
                </div>
                <div class="password-strength" id="passwordStrength" aria-live="polite">
                    <div class="password-strength__bar"><span></span></div>
                    <small class="password-strength__hint">Use 8+ characters with letters, numbers, and a symbol.</small>
                </div>
                <small class="error-message" id="passwordError" role="alert"></small>
            </div>
            <div class="form-group">
                <label class="form-label" for="repeatPassword">Repeat password</label>
                <div class="password-field">
                    <input type="password" id="repeatPassword" name="repeatPassword" class="form-control" placeholder="Repeat your password" autocomplete="new-password" required>
                    <button type="button" class="password-toggle" data-toggle-target="repeatPassword" aria-label="Show password" aria-pressed="false">Show</button>
                </div>
                <small class="error-message" id="repeatPasswordError" role="alert"></small>
            </div>
            <button type="submit" id="submitButton" class="btn btn-primary btn-block">Create account</button>
        </form>

        <div id="verifyModal" class="verify-modal" role="dialog" aria-modal="true" aria-labelledby="verify-title">
            <div class="verify-modal-content">
                <button class="modal-close" type="button" onclick="closeVerifyModal()" aria-label="Close verification dialog">&times;</button>
                <h2 id="verify-title">Verify your email</h2>
                <p>We've sent a verification code to your email address. Please enter it below to continue.</p>

                <div id="messageContainer" class="message-container" role="status" aria-live="polite"></div>

                <div class="input-container">
                    <svg class="mail-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    <input id="codeInput" type="text" placeholder="Enter verification code" maxlength="6" inputmode="numeric" autocomplete="one-time-code" aria-label="Verification code">
                </div>
                <span id="errorContainer" class="error-message" role="alert"></span>

                <div class="resend-container">
                    <p>Didn't receive the code?</p>
                    <button class="resend-btn" id="resendButton" type="button">Resend</button>
                </div>

                <button class="verify-btn" id="verifyButton" type="button">Verify Email</button>

                <p class="terms-text">
                    By signing up, you accept our
                    <a href="#" class="terms-link">Terms and Conditions</a> and
                    <a href="#" class="terms-link">Privacy Policy</a>.
                </p>
            </div>
        </div>

        <p class="signup-footer">
            Already have an account? <a href="/Signin@(string.IsNullOrEmpty(returnUrl) ? "" : "?returnUrl=" + Uri.EscapeDataString(returnUrl))">Sign in here.</a>
        </p>
    </div>
</section>
