@model HomeViewModel
@{
    ViewData["Title"] = "Minigames";
    var hasLocked = Model.Minigames.Any(m => !m.CanAccess);
    var isAuthed = User.Identity?.IsAuthenticated == true;
    var hasMultiplayer = Model.Minigames.Any(m => m.IsMultiplayer);
    var hasPremium = Model.Minigames.Any(m => m.IsPremium);
}

@section Styles {
    <link rel="stylesheet" href="/css/home.css" asp-append-version="true">
}

<section class="home-hero" aria-labelledby="minigames-title">
    <span class="eyebrow">Choose your game</span>
    <h1 id="minigames-title">Minigames</h1>
    <p class="subtitle">Pick a game and challenge yourself — solo or with friends.</p>
</section>

@if (!isAuthed)
{
    <div class="minigames-banner" role="note">
        <span aria-hidden="true">🔓</span>
        <span><a href="/Signin?returnUrl=%2FMinigames">Sign in</a> to save progress and earn coins.</span>
    </div>
}
else if (hasLocked)
{
    <div class="minigames-banner minigames-banner--premium" role="note">
        <span aria-hidden="true">⭐</span>
        <span>Some minigames are premium. <a href="/Market">Unlock more</a> in the Market.</span>
    </div>
}

@if (Model.Minigames.Count == 0)
{
    <article class="sessions-card">
        <h2>No minigames yet</h2>
        <p>Check back soon — new minigames are coming.</p>
    </article>
}
else
{
    <section class="minigame-filters" aria-label="Filter minigames">
        <div class="minigame-filters__search">
            <span class="minigame-filters__search-icon" aria-hidden="true">🔍</span>
            <input
                type="search"
                id="minigame-filter-search"
                class="minigame-filters__input"
                placeholder="Search by name…"
                autocomplete="off"
                aria-label="Search minigames by name" />
        </div>

        <div class="minigame-filters__group" role="radiogroup" aria-label="Game mode">
            <button type="button" class="minigame-chip minigame-chip--active" data-filter-mode="all" role="radio" aria-checked="true">All</button>
            <button type="button" class="minigame-chip" data-filter-mode="single" role="radio" aria-checked="false">Single-player</button>
            @if (hasMultiplayer)
            {
                <button type="button" class="minigame-chip" data-filter-mode="multi" role="radio" aria-checked="false">Multiplayer</button>
            }
        </div>

        @if (hasPremium)
        {
            <div class="minigame-filters__group" role="radiogroup" aria-label="Access tier">
                <button type="button" class="minigame-chip minigame-chip--active" data-filter-tier="all" role="radio" aria-checked="true">Any tier</button>
                <button type="button" class="minigame-chip" data-filter-tier="free" role="radio" aria-checked="false">Free</button>
                <button type="button" class="minigame-chip" data-filter-tier="premium" role="radio" aria-checked="false">Premium</button>
            </div>
        }
    </section>

    <div class="featured-quizzes" id="minigame-list" role="list">
        @foreach (var minigame in Model.Minigames)
        {
            <article class="quiz-card"
                     role="listitem"
                     data-minigame-card
                     data-name="@minigame.DisplayName.ToLowerInvariant()"
                     data-mode="@(minigame.IsMultiplayer ? "multi" : "single")"
                     data-tier="@(minigame.IsPremium ? "premium" : "free")">
                <div class="quiz-image" style="@minigame.CardStyle" aria-hidden="true"></div>
                <div class="quiz-content">
                    <div class="quiz-header">
                        <div class="quiz-badges">
                            @if (minigame.IsPremium)
                            {
                                <span class="premium-badge">Premium</span>
                            }
                            <span class="mode-badge mode-badge--@(minigame.IsMultiplayer ? "multi" : "single")">
                                @(minigame.IsMultiplayer ? "Multiplayer" : "Single-player")
                            </span>
                        </div>
                        <h2>@minigame.DisplayName</h2>
                        <p>@minigame.Description</p>
                    </div>
                    @if (!isAuthed)
                    {
                        <a href="/Signin?returnUrl=@(Uri.EscapeDataString(minigame.LobbyUrl))" class="quiz-btn">Sign in to play</a>
                    }
                    else if (minigame.CanAccess)
                    {
                        <a href="@minigame.LobbyUrl" class="quiz-btn">@minigame.ActionText</a>
                    }
                    else
                    {
                        <a href="/Market" class="quiz-btn quiz-btn-locked">Unlock with Premium</a>
                    }
                </div>
            </article>
        }
    </div>

    <p class="minigame-filters__empty" id="minigame-filter-empty" role="status" hidden>
        No minigames match your filters. <button type="button" class="minigame-filters__reset" id="minigame-filter-reset">Clear filters</button>
    </p>
}

<script src="/js/home.js" asp-append-version="true"></script>
<script src="/js/minigame-filters.js" asp-append-version="true"></script>
