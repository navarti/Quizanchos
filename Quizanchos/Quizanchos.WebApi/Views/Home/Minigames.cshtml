@model HomeViewModel
@{
    ViewData["Title"] = "Minigames";
}
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/home.css">
</head>
<body>
<div class="hero-waves">
    <div class="wave"></div>
    <div class="wave"></div>
    <div class="wave"></div>
</div>
<main>
    <div class="hero-section" style="margin-top: 40px;">
        <h1>Minigames</h1>
        <p class="subtitle">Try other fun games!</p>
        <div class="featured-quizzes">
            @foreach (var minigame in Model.Minigames)
            {
                <div class="quiz-card">
                    <div class="quiz-image" style="@minigame.CardStyle">
                        <div class="quiz-content">
                            <div class="quiz-header">
                                <h2>@minigame.DisplayName</h2>
                                @if (minigame.IsPremium)
                                {
                                    <span class="premium-badge">Premium</span>
                                }
                                <p>@minigame.Description</p>
                            </div>
                            @if (minigame.CanAccess)
                            {
                                <a href="@minigame.LobbyUrl" class="quiz-btn">@minigame.ActionText</a>
                            }
                            else
                            {
                                <span class="quiz-btn quiz-btn-disabled">Premium required</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</main>

<script src="/js/home.js" asp-append-version="true"></script>
</body>
</html>
