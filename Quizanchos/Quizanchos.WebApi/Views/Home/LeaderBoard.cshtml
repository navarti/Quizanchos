@model HomeViewModel
@{
    ViewData["Title"] = "Leaderboard";
}

@section Styles {
    <link rel="stylesheet" href="/css/leaderboard.css" asp-append-version="true">
}

<section class="leaderboard-page">
    <header class="hero">
        <span class="eyebrow">Top players this month</span>
        <h1>Leaderboard</h1>
        <button class="prize-btn" type="button" aria-haspopup="dialog" aria-controls="prizeModal">
            <span class="trophy" aria-hidden="true">🏆</span>
            Monthly Prizes
        </button>
    </header>

    <div class="leaderboard-container">
        <div class="filters" role="tablist" aria-label="Filter by minigame">
            <button class="filter-btn active" type="button" data-minigame="" aria-pressed="true">All</button>
            @foreach (var minigame in Model.Minigames.OrderBy(x => x.Order))
            {
                <button class="filter-btn" type="button" data-minigame="@minigame.MinigameTypeId" aria-pressed="false">@minigame.DisplayName</button>
            }
        </div>

        <div class="leaderboard" data-current-user="@Model.CurrentUserName" aria-live="polite">
            @if (Model.Users == null || Model.Users.Count == 0)
            {
                <div class="leaderboard-empty">
                    <p>No players have scored yet.</p>
                    <p>Be the first — <a href="/Minigames">play a minigame</a> to claim the top spot.</p>
                </div>
            }
            else
            {
                @foreach (var user in Model.Users.Select(u => new { User = u, Rank = u.Position }))
                {
                    var isCurrent = Model.CurrentUserName == user.User.UserName;
                    <div class="leaderboard-item @(isCurrent ? "current-user" : "")" aria-label="Rank @user.Rank, @user.User.UserName, score @user.User.Score">
                        <div class="rank">@user.Rank</div>
                        <div class="player-info">
                            <img src="@user.User.AvatarUrl" alt="" class="player-avatar">
                            <span class="player-name">
                                @user.User.UserName
                                @if (isCurrent)
                                {
                                    <span class="leaderboard-you">you</span>
                                }
                            </span>
                        </div>
                        <div class="score">
                            @if (user.Rank == 1)
                            {
                                <span class="trophy" aria-hidden="true">🏆</span>
                            }
                            <span>@user.User.Score</span>
                        </div>
                    </div>
                }
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="pagination" aria-label="Leaderboard pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <button class="page-btn @(i == Model.CurrentPage ? "active" : "")" type="button" data-page="@i" aria-label="Page @i" aria-current="@(i == Model.CurrentPage ? "page" : null)">@i</button>
                }
            </nav>
        }
    </div>
</section>

<div class="modal" id="prizeModal" role="dialog" aria-modal="true" aria-labelledby="prizeModalTitle">
    <div class="modal-content">
        <h2 id="prizeModalTitle">Monthly Prizes 🏆</h2>
        <div class="prizes">
            <div class="prize">
                <div class="prize-medal" aria-hidden="true">🥇</div>
                <h3>1st Place</h3>
                <p>$100 Amazon Gift Card</p>
            </div>
            <div class="prize">
                <div class="prize-medal" aria-hidden="true">🥈</div>
                <h3>2nd Place</h3>
                <p>$50 Amazon Gift Card</p>
            </div>
            <div class="prize">
                <div class="prize-medal" aria-hidden="true">🥉</div>
                <h3>3rd Place</h3>
                <p>$25 Amazon Gift Card</p>
            </div>
        </div>
        <button class="close-modal" type="button">Close</button>
    </div>
</div>

<script src="/js/leaderboard.js" asp-append-version="true"></script>
