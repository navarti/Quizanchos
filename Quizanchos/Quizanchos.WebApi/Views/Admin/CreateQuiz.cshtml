@{
    ViewData["Title"] = "Create Quiz";
}

@section Styles {
    <link rel="stylesheet" href="/css/createquiz.css" asp-append-version="true">
}

@await Html.PartialAsync("Partials/_AdminPageHeader", new AdminPageHeaderViewModel
{
    Title = "Quiz Category Creator",
    Subtitle = "Build a quiz by defining a category, entities, and their features.",
    BackUrl = "/Admin",
})

<div class="createquiz-page">
    <section class="section" aria-labelledby="section-category">
        <h2 class="section-title" id="section-category">Create or Update Category</h2>

        <div class="category-load-row">
            <select id="existingCategorySelect" class="form-input" aria-label="Existing category">
                <option value="">Select existing category</option>
            </select>
            <button id="loadCategoryButton" type="button" class="form-button">Load</button>
        </div>

        <form id="categoryForm">
            <input type="text" class="form-input" id="categoryName" placeholder="Category name" required>
            <select class="form-input" id="featureType" required aria-label="Feature type">
                <option value="1">Type 1</option>
                <option value="2">Type 2</option>
                <option value="3">Type 3</option>
            </select>
            <input type="text" class="form-input" id="imageUrl" placeholder="Image URL" required>
            <input type="text" class="form-input" id="authorName" placeholder="Author name" required>
            <input type="text" class="form-input" id="questionToDisplay" placeholder="Question to display" required>
            <button type="submit" class="form-button">Save Category</button>
            <button type="button" id="enableEditButton" class="form-button secondary">Edit Category</button>
        </form>
    </section>

    <section class="section" aria-labelledby="section-entities">
        <h2 class="section-title" id="section-entities">Create Quiz Entities</h2>
        <form id="entityForm">
            <input type="text" class="form-input" id="entityName" placeholder="Entity name" required>
            <button type="submit" class="form-button">Add Entity</button>
        </form>
        <ul id="entityList" class="entity-list" aria-live="polite"></ul>
    </section>

    <section class="section" aria-labelledby="section-features">
        <h2 class="section-title" id="section-features">Add Features</h2>
        <form id="featureForm">
            <select class="form-input" id="entitySelect" required aria-label="Entity">
                <option value="">Select entity</option>
            </select>
            <input type="number" class="form-input" id="featureValue" placeholder="Value" required>
            <button type="submit" class="form-button">Add Feature</button>
        </form>
        <ul id="featureList" class="feature-list" aria-live="polite"></ul>
    </section>
</div>

@section Scripts {
    <script src="/js/createquiz.js" asp-append-version="true"></script>
}
