@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="/css/admindash.css" asp-append-version="true">
}

@await Html.PartialAsync("Partials/_AdminPageHeader", new AdminPageHeaderViewModel
{
    Title = Model.PageTitle,
    Subtitle = Model.PageSubtitle,
})

@if (!string.IsNullOrWhiteSpace(Model.LoadError))
{
    @await Html.PartialAsync("Partials/_AdminAlert", new AdminAlertViewModel
    {
        Severity = AdminAlertSeverity.Warning,
        Title = "Some data could not be loaded",
        Message = Model.LoadError,
    })
}

<h2 class="admin-section-heading">Overview</h2>
<section class="admin-stats-grid" aria-label="Platform stats">
    @foreach (var stat in Model.Stats)
    {
        @await Html.PartialAsync("Partials/_AdminStatCard", stat)
    }
</section>

<h2 class="admin-section-heading">Management Tools</h2>
<section class="admin-tools-grid" aria-label="Admin tools">
    @foreach (var tool in Model.Tools)
    {
        @await Html.PartialAsync("Partials/_AdminToolCard", tool)
    }
</section>

@* ----- Modals (DOM-rendered up front; opened by openModal()) ----- *@
<div id="userManagementModal" class="user-management-modal" role="dialog" aria-modal="true" aria-labelledby="user-mgmt-title">
    <div class="user-management-content">
        <button class="modal-close-btn" type="button" onclick="closeModal('userManagementModal')" aria-label="Close">&times;</button>
        <h2 id="user-mgmt-title">User Management</h2>
        <input type="text" id="userSearchInput" class="user-search-input" placeholder="Search by name…" aria-label="Search users by name">

        <div id="userTableLoading" class="admin-loading" hidden>Loading users…</div>
        <div id="userTableEmpty" class="admin-empty" hidden>
            <p class="admin-empty__message">No users match this search.</p>
            <p class="admin-empty__hint">Try a different search term or clear the filter.</p>
        </div>
        <div id="userTableError" class="admin-alert admin-alert--error" hidden role="alert"></div>

        <table id="userTable" class="user-table">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Score</th>
                    <th scope="col" aria-label="Actions"></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
        <div class="user-pagination">
            <button type="button" onclick="changePage(-1)">Previous</button>
            <button type="button" onclick="changePage(1)">Next</button>
        </div>
    </div>
</div>

<div id="categoryManagementModal" class="category-management-modal" role="dialog" aria-modal="true" aria-labelledby="cat-mgmt-title">
    <div class="category-management-content">
        <button class="modal-close-btn" type="button" onclick="closeModal('categoryManagementModal')" aria-label="Close">&times;</button>
        <h2 id="cat-mgmt-title">Category Management</h2>

        <div id="categoryTableLoading" class="admin-loading" hidden>Loading categories…</div>
        <div id="categoryTableEmpty" class="admin-empty" hidden>
            <p class="admin-empty__message">No categories yet.</p>
            <p class="admin-empty__hint">Create one from the <a href="/Admin/CreateQuiz">Create Quiz</a> page.</p>
        </div>
        <div id="categoryTableError" class="admin-alert admin-alert--error" hidden role="alert"></div>

        <table id="categoryTable" class="category-table">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Feature Type</th>
                    <th scope="col">Image</th>
                    <th scope="col">Author</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div id="editFeaturesModal" class="edit-features-modal" role="dialog" aria-modal="true" aria-labelledby="edit-features-title">
    <div class="edit-features-content">
        <button class="modal-close-btn" type="button" onclick="closeModal('editFeaturesModal')" aria-label="Close">&times;</button>
        <h2 id="edit-features-title">Edit Features</h2>

        <div id="featuresTableLoading" class="admin-loading" hidden>Loading features…</div>
        <div id="featuresTableEmpty" class="admin-empty" hidden>
            <p class="admin-empty__message">No features for this category yet.</p>
        </div>
        <div id="featuresTableError" class="admin-alert admin-alert--error" hidden role="alert"></div>

        <table id="featuresTable" class="features-table">
            <thead>
                <tr>
                    <th scope="col">Value</th>
                    <th scope="col">Entity Name</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
        <div id="featuresPagination" class="features-pagination"></div>
    </div>
</div>

@section Scripts {
    <script src="/js/common.js" asp-append-version="true"></script>
    <script src="/js/admindash.js" asp-append-version="true"></script>
}
