@{
    ViewData["Title"] = "Admin Sign in";
}

<section class="admin-auth-shell" aria-labelledby="admin-signin-title">
    <div class="admin-auth-card">
        @await Html.PartialAsync("Partials/_AdminAuthHeader", new AdminAuthHeaderViewModel
        {
            Title = "Admin Sign In",
            Subtitle = "Enter your credentials to access the admin panel.",
        })

        <form id="signinAdminForm" class="signin-form" novalidate>
            <div class="form-group">
                <label class="form-label" for="signinAdminEmail">Email</label>
                <input type="email" id="signinAdminEmail" name="email" class="form-input" placeholder="you@example.com" autocomplete="email" required>
                <span id="signinAdminEmailError" class="error-message" role="alert" style="display:none;"></span>
            </div>
            <div class="form-group">
                <label class="form-label" for="signinAdminPassword">Password</label>
                <input type="password" id="signinAdminPassword" name="password" class="form-input" placeholder="Enter your password" autocomplete="current-password" required>
                <span id="signinAdminPasswordError" class="error-message" role="alert" style="display:none;"></span>
            </div>
            <button type="button" id="signinAdminButton" class="btn btn-primary btn-block">Sign In</button>
        </form>
    </div>
</section>

<div id="errorModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modalHeader">
    <div class="modal-content">
        <button class="close-btn" id="closeModal" type="button" aria-label="Close">&times;</button>
        <h2 id="modalHeader">Notification</h2>
        <p id="modalErrorText"></p>
        <div id="modalButtons" class="modal-buttons"></div>
    </div>
</div>

@section Scripts {
    <script src="/js/common.js" asp-append-version="true"></script>
    <script src="/js/adminsignin.js" asp-append-version="true"></script>
}
