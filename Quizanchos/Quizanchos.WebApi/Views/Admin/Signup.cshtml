@{
    ViewData["Title"] = "Admin Sign up";
}

<section class="admin-auth-shell" aria-labelledby="admin-signup-title">
    <div class="admin-auth-card">
        @await Html.PartialAsync("Partials/_AdminAuthHeader", new AdminAuthHeaderViewModel
        {
            Title = "Admin Sign Up",
            Subtitle = "Create an admin-level account.",
        })

        <form id="registerAdminForm" class="signup-form" novalidate>
            <div class="form-group">
                <label class="form-label" for="registerAdminEmail">Email</label>
                <input type="email" id="registerAdminEmail" name="email" class="form-input" placeholder="you@example.com" autocomplete="email" required>
                <span id="registerAdminEmailError" class="error-message" role="alert" style="display:none;"></span>
            </div>
            <div class="form-group">
                <label class="form-label" for="registerAdminPassword">Password</label>
                <input type="password" id="registerAdminPassword" name="password" class="form-input" placeholder="Enter your password" autocomplete="new-password" required>
                <span id="registerAdminPasswordError" class="error-message" role="alert" style="display:none;"></span>
            </div>
            <div class="form-group">
                <label class="form-label" for="registerAdminConfirmPassword">Confirm Password</label>
                <input type="password" id="registerAdminConfirmPassword" name="confirmPassword" class="form-input" placeholder="Confirm your password" autocomplete="new-password" required>
                <span id="registerAdminConfirmPasswordError" class="error-message" role="alert" style="display:none;"></span>
            </div>
            <button type="button" id="registerAdminButton" class="btn btn-primary btn-block">Register</button>
        </form>
    </div>
</section>

<div id="errorModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modalHeader">
    <div class="modal-content">
        <button class="close-btn" id="closeModal" type="button" aria-label="Close">&times;</button>
        <h2 id="modalHeader">Notification</h2>
        <p id="modalErrorText"></p>
        <div id="modalButtons" class="modal-buttons"></div>
    </div>
</div>

@section Scripts {
    <script src="/js/common.js" asp-append-version="true"></script>
    <script src="/js/admin.js" asp-append-version="true"></script>
}
