@{
    ViewData["Title"] = "Top-Up Orders";
}

@section Styles {
    <link rel="stylesheet" href="/css/admindash.css" asp-append-version="true">
    <link rel="stylesheet" href="/css/admin-topup.css" asp-append-version="true">
}

@await Html.PartialAsync("Partials/_AdminPageHeader", new AdminPageHeaderViewModel
{
    Title = "Top-Up Orders",
    Subtitle = "Confirm or review crypto payments.",
    BackUrl = "/Admin",
})

<div class="topup-admin-page">
    <div id="topup-status" class="topup-status-msg" style="display:none;" role="status" aria-live="polite"></div>

    <div class="topup-tabs" role="tablist" aria-label="Top-up order status">
        <button class="topup-tab active" type="button" data-tab="pending" role="tab" aria-selected="true">Pending</button>
        <button class="topup-tab" type="button" data-tab="history" role="tab" aria-selected="false">History</button>
    </div>

    <section id="tab-pending" class="topup-tab-panel" role="tabpanel" aria-label="Pending orders">
        <div id="pending-loading" class="admin-loading" hidden>Loading pending orders…</div>
        <div id="pending-empty" class="topup-empty" style="display:none;">No pending orders.</div>
        <div id="pending-error" class="admin-alert admin-alert--error" hidden role="alert"></div>

        <table id="pending-table" class="user-table topup-table" style="display:none;">
            <thead>
                <tr>
                    <th scope="col">User</th>
                    <th scope="col">Amount</th>
                    <th scope="col">Coins</th>
                    <th scope="col">Network</th>
                    <th scope="col">Created</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody id="pending-tbody"></tbody>
        </table>
    </section>

    <section id="tab-history" class="topup-tab-panel" role="tabpanel" aria-label="Order history" style="display:none;">
        <div id="history-loading" class="admin-loading" hidden>Loading order history…</div>
        <div id="history-empty" class="topup-empty" style="display:none;">No order history.</div>
        <div id="history-error" class="admin-alert admin-alert--error" hidden role="alert"></div>

        <table id="history-table" class="user-table topup-table" style="display:none;">
            <thead>
                <tr>
                    <th scope="col">User</th>
                    <th scope="col">Amount</th>
                    <th scope="col">Coins</th>
                    <th scope="col">Network</th>
                    <th scope="col">Status</th>
                    <th scope="col">Completed</th>
                </tr>
            </thead>
            <tbody id="history-tbody"></tbody>
        </table>
    </section>
</div>

<div id="confirm-modal" class="user-management-modal" role="dialog" aria-modal="true" aria-labelledby="confirm-title">
    <div class="user-management-content topup-confirm-content">
        <button class="modal-close-btn" id="confirm-close" type="button" aria-label="Close">&times;</button>
        <h2 id="confirm-title">Confirm Top-Up</h2>
        <p>Credit <strong id="confirm-coins"></strong> coins to <strong id="confirm-user"></strong>?</p>
        <p class="topup-confirm-detail">Amount: <span id="confirm-amount"></span> USDT · Network: <span id="confirm-network"></span></p>
        <div class="topup-confirm-field">
            <label for="confirm-txid">Transaction ID (optional)</label>
            <input type="text" id="confirm-txid" placeholder="Binance TxId…">
        </div>
        <div class="topup-confirm-actions">
            <button class="topup-btn-confirm" id="confirm-yes" type="button">Confirm &amp; Credit</button>
            <button class="topup-btn-cancel" id="confirm-no" type="button">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/common.js" asp-append-version="true"></script>
    <script src="/js/admin-topup.js" asp-append-version="true"></script>
}
