@{
    ViewData["Title"] = "Quiz Page";
}
@using Quizanchos.Common.Enums;
@using Quizanchos.Common.Quiz.Enums
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="/minigames/quiz/css/quiz.css">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
</head>
<body>
<div class="container game-session-container">
    <div class="header">
        <h1 class="game-title" id="categoryName">Loading...</h1>
        <p class="game-subtitle">Customize your quest below!</p>
    </div>

    <form id="gameSettingsForm" class="game-settings-form" data-category-id="@ViewBag.CategoryId">
        <div class="form-group">
            <label for="gameLevel">Game Level:</label>
            <select id="gameLevel" name="gameLevel" class="form-control">
                @foreach (var level in Enum.GetValues(typeof(GameLevel)))
                {
                    <option value="@((int)level)">@level</option>
                }
            </select>
        </div>
        
        <div class="form-group">
            <label for="cardsCount">Number of Cards:</label>
            <select id="cardsCount" name="cardsCount" class="form-control">
                @foreach (var value in Enum.GetValues(typeof(CardCountEnum)))
                {
                    <option value="@((int)value)">@value</option>
                }
            </select>
        </div>
        
        <div class="form-group">
            <label for="secondsPerCard">Time per Card (seconds):</label>
            <select id="secondsPerCard" name="secondsPerCard" class="form-control">
                @foreach (var value in Enum.GetValues(typeof(SecondsPerCardEnum)))
                {
                    <option value="@((int)value)">@value</option>
                }
            </select>
        </div>
        
        <div class="form-group">
            <label for="optionCount">Number of Options per Card:</label>
            <select id="optionCount" name="optionCount" class="form-control">
                @foreach (var value in Enum.GetValues(typeof(OptionCountEnum)))
                {
                    <option value="@((int)value)">@value</option>
                }
            </select>
        </div>
        <div class="action-buttons">
            <button type="button" id="startQuestButton" class="btn-start-quiz">Start Quest</button>
            <a href="/" class="btn-back-to-quizzes">Back to Quizzes</a>
        </div>
    </form>
</div>

<script>
    window.minigameConfig = {
        minigameTypeId: @ViewBag.MinigameTypeId,
        gameUrlTemplate: '@ViewBag.GameUrlTemplate',
        lobbyUrl: '@ViewBag.LobbyUrl'
    };

    // Load category name on page load
    document.addEventListener('DOMContentLoaded', async () => {
        const form = document.getElementById('gameSettingsForm');
        const categoryId = form.getAttribute('data-category-id');
        
        try {
            const response = await fetch(`/QuizCategory/GetById?id=${categoryId}`);
            if (response.ok) {
                const category = await response.json();
                document.getElementById('categoryName').textContent = category.name || 'Quiz';
            }
        } catch (error) {
            console.error('Error loading category:', error);
        }
    });
</script>
<script src="/js/game-client.js" asp-append-version="true"></script>
<script src="/minigames/quiz/js/quiz-client.js" asp-append-version="true"></script>
<script src="/js/common.js" asp-append-version="true"></script>
<script src="/js/site.js"></script>
</body>
</html>



