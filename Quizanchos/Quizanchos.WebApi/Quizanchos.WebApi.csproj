<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <InvariantGlobalization>false</InvariantGlobalization>
    <UserSecretsId>b4de0428-9c94-4d16-943b-80363386d430</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Dto\Abstractions\**" />
    <Content Remove="Dto\Abstractions\**" />
    <EmbeddedResource Remove="Dto\Abstractions\**" />
    <None Remove="Dto\Abstractions\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CloudinaryDotNet" Version="1.28.0" />
    <PackageReference Include="FluentEmail.Mailgun" Version="3.0.2" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Google" Version="10.0.2" />
    <PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" Version="10.0.2" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="10.0.2" />
    <PackageReference Include="Microsoft.VisualStudio.Web.CodeGeneration.Design" Version="10.0.2" />
    <PackageReference Include="Quartz" Version="3.15.1" />
    <PackageReference Include="Quartz.Extensions.DependencyInjection" Version="3.15.1" />
    <PackageReference Include="Quartz.Extensions.Hosting" Version="3.15.1" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.0" />
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerGen" Version="10.1.0" />
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI" Version="10.1.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Minigames\Quiz\Quizanchos.Quiz.DbUpdater\Quizanchos.Quiz.DbUpdater.csproj" />
    <ProjectReference Include="..\Quizanchos.Common\Quizanchos.Common.csproj" />
    <ProjectReference Include="..\Quizanchos.Core\Quizanchos.Core.csproj" />
    <ProjectReference Include="..\Quizanchos.Domain\Quizanchos.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <MinigamePluginProject Include="..\Quizanchos.Game2048\Quizanchos.Game2048.csproj" />
    <MinigamePluginProject Include="..\Minigames\QuizMultiplayer\Quizanchos.QuizMultiplayer\Quizanchos.QuizMultiplayer.csproj" />
  </ItemGroup>

  <Target Name="BuildAndCopyMinigamePlugins" AfterTargets="Build">
    <MSBuild Projects="@(MinigamePluginProject)" Targets="Build" Properties="Configuration=$(Configuration);TargetFramework=$(TargetFramework)" />

    <ItemGroup>
      <_MinigamePluginDll Include="@(MinigamePluginProject->'%(RootDir)%(Directory)bin\$(Configuration)\$(TargetFramework)\%(Filename).dll')" Condition="Exists('%(Identity)')" />
    </ItemGroup>

    <Copy SourceFiles="@(_MinigamePluginDll)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="PublishMinigamePlugins" AfterTargets="ComputeFilesToPublish">
    <ItemGroup>
      <_MinigamePluginDllForPublish Include="@(MinigamePluginProject->'%(RootDir)%(Directory)bin\$(Configuration)\$(TargetFramework)\%(Filename).dll')" Condition="Exists('%(Identity)')" />
      <ResolvedFileToPublish Include="@(_MinigamePluginDllForPublish)">
        <RelativePath>%(Filename)%(Extension)</RelativePath>
        <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      </ResolvedFileToPublish>
    </ItemGroup>
  </Target>

</Project>
