# Build context = repo root. Strip everything Docker doesn't need so the
# layer-cache key is stable and 'COPY . .' doesn't pull in build artifacts.
**/bin
**/obj
**/.vs
**/.vscode
**/.idea
**/logs
**/publish
**/publish-test
**/TestResults

.git
.github
.gitignore
.gitattributes

# Secrets & local-only files
**/.env
**/.env.*
!**/.env.example

# IDE / Claude state
.claude
**/.claude
**/CLAUDE.md

# Docs (don't bust cache when only README changes)
**/*.md

# Local nupkg cache — the Dockerfile re-packs from source.
Quizanchos/nupkgs

# Sample plugin (separate from the Minigames/ solution)
Quizanchos/samples
